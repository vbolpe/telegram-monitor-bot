# ──────────────────────────────────────────────
#  Configuración del Bot de Monitoreo de Red
# ──────────────────────────────────────────────

# Token del bot (obtenelo hablando con @BotFather en Telegram)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Chat ID al que se enviarán los informes
# Puede ser un chat privado, grupo o canal
# Para obtenerlo: enviá un mensaje al bot y consultá
# https://api.telegram.org/bot<TOKEN>/getUpdates
CHAT_ID=-1001234567890

# Ruta al archivo Excel dentro del contenedor (no cambiar salvo que modifiques el volumen)
EXCEL_PATH=/data/red.xlsx
